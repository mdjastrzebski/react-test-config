{
  "name": "react-test-config",
  "version": "0.3.0",
  "description": "Configure React testing environment",
  "keywords": [
    "jest",
    "owner-stacks",
    "react",
    "testing"
  ],
  "license": "MIT",
  "author": "",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "validate:fix": "pnpm typecheck && pnpm format",
    "release": "release-it"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "24.1.0",
    "@types/react": "^19.0.0",
    "oxfmt": "^0.54.0",
    "react": "^19.0.0",
    "release-it": "^20.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.0.0",
    "unrun": "^0.3.1"
  },
  "peerDependencies": {
    "react": "*"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
