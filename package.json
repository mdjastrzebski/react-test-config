{
  "name": "react-test-config",
  "version": "0.0.1",
  "description": "Configure React testing environment",
  "license": "MIT",
  "author": "",
  "packageManager": "pnpm@10.33.2",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "release": "release-it"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "release-it": "^20.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.0.0",
    "unrun": "^0.3.1"
  },
  "keywords": [
    "react",
    "testing",
    "jest",
    "owner-stacks"
  ]
}
